{
  "platform": {
    "apiRuntime": "node:20"
  },
  "routes": [
    {
      "route": "/analytics",
      "redirect": "/stats",
      "statusCode": 301
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/*.{png,jpg,jpeg,gif,svg,webp,ico,webmanifest}",
      "/manifest.webmanifest"
    ]
  },
  "mimeTypes": {
    ".webmanifest": "application/manifest+json"
  },
  "globalHeaders": {
    "Service-Worker-Allowed": "/"
  }
}
