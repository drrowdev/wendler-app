{
  "name": "wendler-app",
  "version": "0.0.1",
  "private": true,
  "description": "Wendler 5/3/1 progressive web app",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @wendler/web dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "eval": "pnpm --filter @wendler/eval eval",
    "eval:refresh": "pnpm --filter @wendler/eval eval:refresh",
    "eval:strict": "pnpm --filter @wendler/eval eval:strict"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  }
}
